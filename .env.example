# ==============================
# UrbanLayer — Variáveis de Ambiente
# ==============================
# Copie este arquivo para .env e preencha com suas chaves reais.
# NUNCA commitar o .env com chaves reais!

# ===== AI (Server-side — NÃO usar prefixo VITE_) =====
# Token do Replicate para geração de imagens via IA
# ⚠️ IMPORTANTE: Sem prefixo VITE_ para NÃO expor no bundle frontend
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave do Gemini (não usado atualmente, reservado para futuro)
GEMINI_API_KEY=

# ===== Maps (Frontend — prefixo VITE_ necessário) =====
# Google Maps JavaScript API + Street View Static API
VITE_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mapbox GL (Globo 3D)
VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Database (Frontend — prefixo VITE_ necessário) =====
# Supabase — URL do projeto
VITE_SUPABASE_URL=https://xxxxxxxxxx.supabase.co

# Supabase — Chave anônima (segura para frontend)
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxx

# ===== Blockchain (Frontend — prefixo VITE_ necessário) =====
# Endereço do contrato GraffitiSpot deployado
# Ink Sepolia: 0x44AA57E2e4079D2cC680F468e0d53E2Ad362137F
VITE_INK_CONTRACT_ADDRESS=0x44AA57E2e4079D2cC680F468e0d53E2Ad362137F

# Toggle testnet/mainnet (true = Ink Sepolia, false = Ink Mainnet)
VITE_USE_TESTNET=true
